<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add New Book - My Book Tracker</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <div class="container">

    <!-- HEADER -->
    <header class="site-header">
      <div class="header-left">
        <h1>📚 Add New Book</h1>
        <p class="subtitle">Add a book to your collection</p>
      </div>
      <a href="/" class="btn btn-secondary">← Back</a>
    </header>

    <!-- ERROR MESSAGE (shown if form submission fails) -->
    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>

    <div class="form-layout">

      <!-- BOOK COVER PREVIEW (updates live as user types ISBN) -->
      <div class="cover-preview-box">
        <img id="cover-preview" src="/placeholder.jpg" alt="Book cover preview" />
        <p class="preview-label">Cover preview</p>
      </div>

      <!-- ADD BOOK FORM -->
      <form method="POST" action="/add" class="book-form">

        <div class="form-group">
          <label for="title">Title <span class="required">*</span></label>
          <input type="text" id="title" name="title" placeholder="e.g. Atomic Habits" required />
        </div>

        <div class="form-group">
          <label for="author">Author <span class="required">*</span></label>
          <input type="text" id="author" name="author" placeholder="e.g. James Clear" required />
        </div>

        <div class="form-group">
          <label for="isbn">ISBN</label>
          <input
            type="text"
            id="isbn"
            name="isbn"
            placeholder="e.g. 9780735211292"
            oninput="previewCover(this.value)"
          />
          <small>Optional — used to fetch the book cover automatically</small>
        </div>

        <div class="form-group">
          <label for="rating">Rating <span class="required">*</span></label>
          <select id="rating" name="rating" required>
            <option value="">Select a rating</option>
            <option value="1">⭐ 1 — Poor</option>
            <option value="2">⭐⭐ 2 — Fair</option>
            <option value="3">⭐⭐⭐ 3 — Good</option>
            <option value="4">⭐⭐⭐⭐ 4 — Very Good</option>
            <option value="5">⭐⭐⭐⭐⭐ 5 — Excellent</option>
          </select>
        </div>

        <div class="form-group">
          <label for="date_read">Date Read</label>
          <input type="date" id="date_read" name="date_read" />
        </div>

        <div class="form-group">
          <label for="notes">Notes</label>
          <textarea id="notes" name="notes" rows="8" placeholder="Paste or type anything about this book — summary, quotes, key takeaways, thoughts..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Add Book</button>

      </form>
    </div>

  </div>

  <script>
    // Live cover preview — fetches image from Open Library as user types ISBN
    function previewCover(isbn) {
      const img = document.getElementById("cover-preview");
      if (isbn.length >= 10) {
        img.src = `https://covers.openlibrary.org/b/isbn/${isbn}-M.jpg`;
        img.onerror = () => { img.onerror = null; img.src = "/placeholder.jpg"; };
      } else {
        img.src = "/placeholder.jpg";
      }
    }
  </script>

</body>
</html>
