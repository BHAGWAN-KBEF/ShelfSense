# =============================================
# LOCAL DEVELOPMENT — fill these in for local use
# =============================================
DB_USER=postgres
DB_HOST=localhost
DB_NAME=booktracker
DB_PASSWORD=your_password_here
DB_PORT=5432

# =============================================
# PRODUCTION (Render + Supabase)
# Set DATABASE_URL in Render dashboard instead of the DB_* vars above
# Format: postgresql://user:password@host:port/dbname
# =============================================
# DATABASE_URL=your_supabase_connection_string_here

# =============================================
# SERVER
# =============================================
PORT=3000
SESSION_SECRET=your_secret_key_here
