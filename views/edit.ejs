<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Book - My Book Tracker</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <div class="container">

    <!-- HEADER -->
    <header class="site-header">
      <div class="header-left">
        <h1>📚 Edit Book</h1>
        <p class="subtitle">Update your book details</p>
      </div>
      <a href="/" class="btn btn-secondary">← Back</a>
    </header>

    <!-- ERROR MESSAGE -->
    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>

    <div class="form-layout">

      <!-- LIVE COVER PREVIEW -->
      <div class="cover-preview-box">
        <img
          id="cover-preview"
          src="<%= book.isbn ? 'https://covers.openlibrary.org/b/isbn/' + book.isbn + '-M.jpg' : '/placeholder.jpg' %>"
          alt="Book cover preview"
          onerror="this.src='/placeholder.jpg'"
        />
        <p class="preview-label">Cover preview</p>
      </div>

      <!-- EDIT FORM — pre-filled with existing book data -->
      <form method="POST" action="/edit/<%= book.id %>" class="book-form">

        <div class="form-group">
          <label for="title">Title <span class="required">*</span></label>
          <input type="text" id="title" name="title" value="<%= book.title %>" required />
        </div>

        <div class="form-group">
          <label for="author">Author <span class="required">*</span></label>
          <input type="text" id="author" name="author" value="<%= book.author %>" required />
        </div>

        <div class="form-group">
          <label for="isbn">ISBN</label>
          <input
            type="text"
            id="isbn"
            name="isbn"
            value="<%= book.isbn || '' %>"
            placeholder="e.g. 9780735211292"
            oninput="previewCover(this.value)"
          />
          <small>Optional — used to fetch the book cover automatically</small>
        </div>

        <div class="form-group">
          <label for="rating">Rating <span class="required">*</span></label>
          <select id="rating" name="rating" required>
            <option value="">Select a rating</option>
            <option value="1" <%= book.rating === 1 ? 'selected' : '' %>>⭐ 1 — Poor</option>
            <option value="2" <%= book.rating === 2 ? 'selected' : '' %>>⭐⭐ 2 — Fair</option>
            <option value="3" <%= book.rating === 3 ? 'selected' : '' %>>⭐⭐⭐ 3 — Good</option>
            <option value="4" <%= book.rating === 4 ? 'selected' : '' %>>⭐⭐⭐⭐ 4 — Very Good</option>
            <option value="5" <%= book.rating === 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐ 5 — Excellent</option>
          </select>
        </div>

        <div class="form-group">
          <label for="date_read">Date Read</label>
          <input type="date" id="date_read" name="date_read" value="<%= book.date_read || '' %>" />
        </div>

        <div class="form-group">
          <label for="notes">Notes</label>
          <textarea id="notes" name="notes" rows="4"><%= book.notes || '' %></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-full">Save Changes</button>

      </form>
    </div>

  </div>

  <script>
    function previewCover(isbn) {
      const img = document.getElementById("cover-preview");
      if (isbn.length >= 10) {
        img.src = `https://covers.openlibrary.org/b/isbn/${isbn}-M.jpg`;
        img.onerror = () => { img.onerror = null; img.src = "/placeholder.jpg"; };
      } else {
        img.src = "/placeholder.jpg";
      }
    }
  </script>

</body>
</html>
